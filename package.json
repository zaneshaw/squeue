{
  "name": "@zaneshaw/squeue",
  "version": "1.1.1",
  "description": "A lightweight queue/job system",
  "author": "Zane Shaw <zane@squidee.dev> (https://squidee.dev)",
  "license": "MIT",
  "homepage": "https://github.com/zaneshaw/squeue#readme",
  "bugs": {
    "url": "https://github.com/zaneshaw/squeue/issues"
  },
  "keywords": [
    "queue",
    "job",
    "task"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun run build:esm && bun run build:cjs && bun run build:declaration",
    "build:esm": "bun build ./src/index.ts --external '*' --format esm --outdir dist/",
    "build:cjs": "bun build ./src/index.ts --external '*' --format cjs --outfile dist/index.cjs",
    "build:declaration": "tsc --emitDeclarationOnly --project tsconfig.types.json",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "uuidv7": "^1.1.0"
  }
}
